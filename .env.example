# Copy this file to .env on the server and fill real Finnhub credentials.
DATA_SOURCE=finnhub
FINNHUB_API_KEY=
FINNHUB_STREAM_TIMEOUT_SECONDS=8

# Runtime tuning.
LOG_LEVEL=INFO
SCHEDULER_ENABLED=false
REFRESH_INTERVAL_SECONDS=60
LATEST_CACHE_TTL_SECONDS=120
LAST_SUCCESS_TTL_SECONDS=86400
RATE_LIMIT_PER_MINUTE=120
